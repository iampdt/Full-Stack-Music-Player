{
  "name": "spotify-clone",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:clean": "pkill -f 'next dev' || true; pkill -f 'next/dist/compiled/jest-worker/processChild.js' || true; rm -rf .next",
    "dev:fresh": "npm run dev:clean && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:reset:seed": "psql \"$SUPABASE_DB_URL\" -f scripts/reset_and_seed.sql",
    "stripe:check": "node scripts/check_stripe_config.mjs",
    "stripe:sync:catalog": "node scripts/sync_stripe_catalog.mjs",
    "stripe:doctor": "npm run stripe:check && npm run stripe:sync:catalog",
    "stripe:listen": "stripe listen --forward-to localhost:3000/api/webhooks"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.0.4",
    "@radix-ui/react-slider": "^1.1.2",
    "@stripe/stripe-js": "^1.54.1",
    "@supabase/auth-helpers-nextjs": "^0.7.2",
    "@supabase/auth-helpers-react": "^0.4.0",
    "@supabase/auth-ui-react": "^0.4.2",
    "@supabase/auth-ui-shared": "^0.1.6",
    "@supabase/supabase-js": "^2.26.0",
    "@types/node": "^20.2.5",
    "@types/react": "^18.2.8",
    "@types/react-dom": "^18.2.4",
    "@types/uniqid": "^5.3.2",
    "autoprefixer": "10.4.14",
    "encoding": "^0.1.13",
    "eslint": "8.42.0",
    "eslint-config-next": "13.4.4",
    "next": "13.4.4",
    "postcss": "8.4.24",
    "query-string": "^8.1.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-hook-form": "^7.44.3",
    "react-hot-toast": "^2.4.1",
    "react-icons": "^4.9.0",
    "react-spinners": "^0.13.8",
    "stripe": "^12.8.0",
    "tailwind-merge": "^1.13.0",
    "tailwindcss": "3.3.2",
    "typescript": "6.0.3",
    "uniqid": "^5.4.0",
    "use-sound": "^4.0.1",
    "zustand": "^4.3.8"
  },
  "devDependencies": {
    "supabase": "^1.64.8"
  }
}
