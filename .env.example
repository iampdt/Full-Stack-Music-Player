NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_URL=

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PAYMENT_LINK=
# Optional if using separate live webhook secret
STRIPE_WEBHOOK_SECRET_LIVE=

# Optional auth providers for AuthModal
NEXT_PUBLIC_ENABLE_GOOGLE_AUTH=false
NEXT_PUBLIC_ENABLE_APPLE_AUTH=false
NEXT_PUBLIC_ENABLE_GITHUB_AUTH=false

# Optional for local Stripe scripts
# Export these when running npm run stripe:check / stripe:sync:catalog
# source .env.local && npm run stripe:check

# Optional deployment URL helpers
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_VERCEL_URL=
